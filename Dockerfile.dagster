FROM python:3.12-slim

RUN pip install --no-cache-dir \
    dagster \
    dagster-graphql \
    dagster-webserver \
    dagster-postgres \
    dagster-docker

ENV DAGSTER_HOME=/opt/dagster/dagster_home/

RUN mkdir -p $DAGSTER_HOME

COPY dagster/dagster.yaml dagster/workspace.yaml $DAGSTER_HOME

WORKDIR $DAGSTER_HOME
